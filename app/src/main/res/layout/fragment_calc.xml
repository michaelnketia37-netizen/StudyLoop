<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_diagonal">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="🧮 Calculator" android:textSize="24sp" android:textStyle="bold"
        android:textColor="@color/text" android:padding="20dp"/>

    <!-- MODE SELECTOR (shown first) -->
    <LinearLayout
        android:id="@+id/layout_mode_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="8dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_std"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@color/surface" app:cardCornerRadius="16dp"
            app:strokeColor="@color/border" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:padding="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔢" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Standard" android:textStyle="bold" android:textColor="@color/text" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FREE" android:textSize="10sp" android:textColor="@color/green"
                    android:fontFamily="monospace" android:layout_marginTop="4dp"
                    android:background="@drawable/chip_green" android:paddingLeft="8dp"
        android:paddingRight="8dp" android:paddingTop="2dp"
        android:paddingBottom="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_sci"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="6dp"
            app:cardBackgroundColor="@color/surface" app:cardCornerRadius="16dp"
            app:strokeColor="@color/border" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:padding="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔬" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scientific" android:textStyle="bold" android:textColor="@color/text" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▶ Watch Ad" android:textSize="10sp" android:textColor="@color/orange"
                    android:fontFamily="monospace" android:layout_marginTop="4dp"
                    android:background="@drawable/chip_orange" android:paddingLeft="8dp"
        android:paddingRight="8dp" android:paddingTop="2dp"
        android:paddingBottom="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- STANDARD CALCULATOR (hidden until selected) -->
    <LinearLayout
        android:id="@+id/layout_standard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <Button android:id="@+id/btn_back_std"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← Modes" android:textSize="11sp"
            android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp" android:layout_marginBottom="6dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- Display -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp" android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/surface" app:cardCornerRadius="16dp"
            app:strokeColor="@color/border" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp" android:minHeight="110dp"
                android:gravity="bottom|end">
                <TextView android:id="@+id/tv_std_tape"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="end" android:textSize="11sp" android:textColor="@color/text3"
                    android:fontFamily="monospace" android:singleLine="true" android:ellipsize="start"/>
                <TextView android:id="@+id/tv_std_result"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="end" android:textSize="42sp" android:textStyle="bold"
                    android:textColor="@color/text" android:fontFamily="monospace"
                    android:singleLine="true" android:ellipsize="start" android:text="0"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Button grid -->
        <GridLayout android:id="@+id/grid_std"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
            android:columnCount="4" android:rowCount="5"
            android:useDefaultMargins="true"/>
    </LinearLayout>

    <!-- SCIENTIFIC CALCULATOR (hidden until ad watched) -->
    <ScrollView
        android:id="@+id/layout_scientific"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Toolbar row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="8dp"
        android:paddingRight="8dp" android:paddingBottom="6dp">
                <Button android:id="@+id/btn_back_sci"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="←" android:textSize="13sp" android:minWidth="0dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:paddingLeft="8dp"
        android:paddingRight="8dp"/>
                <RadioGroup android:id="@+id/rg_sci_mode"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginStart="6dp">
                    <RadioButton android:id="@+id/rb_norm" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="NORM"
                        android:textSize="9sp" android:checked="true" android:fontFamily="monospace"/>
                    <RadioButton android:id="@+id/rb_math" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="MATH"
                        android:textSize="9sp" android:fontFamily="monospace"/>
                    <RadioButton android:id="@+id/rb_deci" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="DECI"
                        android:textSize="9sp" android:fontFamily="monospace"/>
                </RadioGroup>
                <Button android:id="@+id/btn_deg_rad"
                    android:layout_width="wrap_content" android:layout_height="30dp"
                    android:text="DEG" android:textSize="9sp" android:minWidth="0dp"
                    android:layout_marginStart="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:paddingLeft="8dp"
        android:paddingRight="8dp" android:fontFamily="monospace"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView android:id="@+id/tv_unlocked"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔓 UNLOCKED" android:textSize="9sp" android:textColor="@color/green"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!-- Green Casio display -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
                android:layout_marginBottom="6dp" android:background="@drawable/calc_display_bg"
                android:padding="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tv_ind_shift"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SHIFT" android:textSize="9sp" android:textStyle="bold"
                        android:fontFamily="monospace" android:textColor="#000"
                        android:background="@drawable/ind_shift_bg" android:paddingLeft="3dp"
        android:paddingRight="3dp"
                        android:layout_marginEnd="4dp" android:visibility="invisible"/>
                    <TextView android:id="@+id/tv_ind_alpha"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ALPHA" android:textSize="9sp" android:textStyle="bold"
                        android:fontFamily="monospace" android:textColor="@color/white"
                        android:background="@drawable/ind_alpha_bg" android:paddingLeft="3dp"
        android:paddingRight="3dp"
                        android:layout_marginEnd="4dp" android:visibility="invisible"/>
                    <TextView android:id="@+id/tv_ind_hyp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HYP" android:textSize="9sp" android:textStyle="bold"
                        android:fontFamily="monospace" android:textColor="@color/white"
                        android:background="@drawable/ind_hyp_bg" android:paddingLeft="3dp"
        android:paddingRight="3dp"
                        android:visibility="invisible"/>
                    <TextView android:id="@+id/tv_ind_mem"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="end"
                        android:textSize="9sp" android:textColor="#1a2a1a" android:fontFamily="monospace"/>
                </LinearLayout>
                <TextView android:id="@+id/tv_sci_expr"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="0" android:textSize="15sp" android:textColor="#1a2a1a"
                    android:fontFamily="monospace" android:minHeight="24dp"/>
                <TextView android:id="@+id/tv_sci_ans"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="end" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="#1a2a1a" android:fontFamily="monospace" android:minHeight="28dp"/>
            </LinearLayout>

            <!-- Keypad rows are added programmatically in CalcFragment -->
            <LinearLayout android:id="@+id/ll_sci_keypad"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:paddingLeft="5dp"
        android:paddingRight="5dp"/>

            <!-- Constants strip -->
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="4dp" android:paddingLeft="5dp"
        android:paddingRight="5dp">
                <LinearLayout android:id="@+id/ll_constants"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <View android:layout_width="match_parent" android:layout_height="10dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- AD GATE -->
    <ScrollView android:id="@+id/layout_ad_gate"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:visibility="gone">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:padding="18dp">

            <Button android:id="@+id/btn_back_ad"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="← Modes" android:layout_gravity="start"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔬" android:textSize="64sp" android:layout_marginTop="16dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Unlock Scientific Calculator"
                android:textSize="20sp" android:textStyle="bold" android:textColor="@color/text"
                android:layout_marginTop="12dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Watch a short ad to access the full\nCasio-style scientific calculator"
                android:textSize="13sp" android:textColor="@color/text2"
                android:gravity="center" android:layout_marginTop="8dp" android:layout_marginBottom="16dp"/>

            <Button android:id="@+id/btn_watch_ad"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="▶  Watch Ad to Unlock (~15s)"
                android:backgroundTint="@color/orange" android:textColor="@color/black"
                android:textStyle="bold" android:textSize="15sp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Unlocks for this session · No purchase required"
                android:textSize="10sp" android:textColor="@color/text3"
                android:fontFamily="monospace" android:layout_marginTop="8dp"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
