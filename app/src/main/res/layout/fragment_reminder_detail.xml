<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_diagonal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_diagonal"
            app:navigationIcon="@drawable/ic_back"
            app:title="Reminder Detail"
            app:titleTextColor="@color/text"/>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
            android:layout_marginBottom="14dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:id="@+id/tv_retention_val"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="@color/accent"
                        android:fontFamily="monospace"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Current retention" android:textSize="11sp" android:textColor="@color/text3"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:id="@+id/tv_next_review"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="@color/accent3"
                        android:fontFamily="monospace"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Next review in" android:textSize="11sp" android:textColor="@color/text3"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Forgetting curve chart -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📉 Forgetting Curve — Retention Over Time"
                    android:textSize="11sp" android:textColor="@color/text2"
                    android:fontFamily="monospace" android:layout_marginBottom="10dp"/>
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/forgetting_chart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Review timeline -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
            android:layout_marginBottom="14dp">
            <LinearLayout
                android:id="@+id/ll_timeline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>

        <!-- Content card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Content" android:textStyle="bold"
                    android:textColor="@color/text" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tv_content"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/text2" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mark reviewed button -->
        <Button
            android:id="@+id/btn_reviewed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
            android:text="✓ Mark as Reviewed"
            android:backgroundTint="@color/green"
            android:textColor="@color/black"/>

    </LinearLayout>
</ScrollView>
